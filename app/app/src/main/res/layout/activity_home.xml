<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:ignore="MissingConstraints">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/obem_header_bk"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingBottom="20dp"
                android:paddingTop="40dp">

                <TextView
                    android:id="@+id/welcome"
                    android:fontFamily="@font/karla_bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/whiteTextColor"/>

                <ImageView
                    android:id="@+id/logout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@+id/welcome"
                    android:src="@drawable/ic_setting"
                    android:layout_marginStart="150dp" />


                <TextView
                    android:id="@+id/name"
                    style="@style/viewParent.headerText"
                    android:textColor="@color/whiteTextColor"
                    android:layout_below="@id/welcome"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="70dp"/>


            </RelativeLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/cardLayout">

                <TextView
                    android:id="@+id/stat"
                    style="@style/viewParent.headerText"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="15dp"
                    android:text="THIS WEEK'S READING"
                    />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/cardLayout2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/headerLayout"
                android:layout_marginTop="130dp">

                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#F2F3F4"
                    style="@style/reportsCardStyle">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical">

                        <TextView
                            style="@style/reportContentText"
                            android:fontFamily="@font/karla_bold"
                            android:textColor="@color/violet"
                            android:layout_marginLeft="5dp"
                            android:text="BLOOD PRESSURE"/>

                        <TextView

                            android:id="@+id/bp"
                            android:fontFamily="@font/karla_bold"
                            style="@style/viewParent.headerText"
                            android:textColor="@color/violet"
                            android:layout_marginLeft="25dp"
                            android:textSize="27sp"
                            />

                        <TextView
                            android:id="@+id/bpV"
                            style="@style/viewParent.headerText"
                            android:layout_marginLeft="20dp"
                            android:textSize="16sp"

                            />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#F2F3F4"
                    style="@style/reportsCardStyle">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical">

                        <TextView
                            style="@style/reportContentText"
                            android:textColor="@color/violet"
                            android:fontFamily="@font/karla_bold"
                            android:layout_marginLeft="10dp"
                            android:text="BlOOD SUGAR"/>

                        <TextView
                            android:id="@+id/sugar"
                            style="@style/viewParent.headerText"
                            android:textColor="@color/violet"
                            android:layout_marginLeft="30dp"
                            android:textSize="27sp"
                            />
                        <TextView
                            android:id="@+id/sugarV"
                            style="@style/viewParent.headerText"
                            android:layout_marginLeft="20dp"
                            android:textSize="16sp"
                            />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/headerLayout"
                android:layout_marginTop="-60dp">

                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/whiteTextColor"
                    style="@style/reportsCardStyle">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical">

                        <TextView
                            style="@style/reportContentText"
                            android:textColor="@color/violet"
                            android:fontFamily="@font/karla_bold"
                            android:text="START WEIGHT"/>
                        <TextView
                            android:id="@+id/sweight"
                            android:textColor="@color/violet"
                            style="@style/viewParent.headerText"
                            android:layout_marginLeft="30dp"
                            android:textSize="27sp"
                            />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/whiteTextColor"
                    style="@style/reportsCardStyle">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical">

                        <TextView
                            style="@style/reportContentText"
                            android:textColor="@color/violet"
                            android:fontFamily="@font/karla_bold"
                            android:text="CURRENT WEIGHT"/>

                        <TextView
                            android:id="@+id/cweight"
                            android:textColor="@color/violet"
                            style="@style/viewParent.headerText"
                            android:layout_marginLeft="30dp"
                            android:textSize="27sp"
                            />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardLayout3"
                android:layout_width="match_parent"
                android:layout_centerInParent="true"
                android:layout_height="wrap_content"
                android:layout_below="@id/headerLayout"
                android:layout_marginTop="280dp">

                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    android:layout_margin="5dp"
                    app:cardBackgroundColor="#F2F3F4"
                    style="@style/reportsCardStyle">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical">

                        <TextView
                            style="@style/reportContentText"
                            android:textColor="@color/violet"
                            android:fontFamily="@font/karla_bold"
                            android:text="BMI"/>

                        <TextView
                            android:id="@+id/bmi"
                            style="@style/viewParent.headerText"
                            android:textColor="@color/violet"
                            android:textSize="27sp"
                            />
                        <TextView
                            android:id="@+id/bmiV"
                            style="@style/viewParent.headerText"
                            android:textSize="16sp"
                            />


                    </LinearLayout>

                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    android:layout_margin="5dp"
                    app:cardBackgroundColor="#F2F3F4"
                    style="@style/reportsCardStyle">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical">

                        <TextView
                            style="@style/reportContentText"
                            android:textColor="@color/violet"
                            android:fontFamily="@font/karla_bold"
                            android:text="CHOLESTEROL"/>
                        <TextView
                            android:id="@+id/calorie"
                            style="@style/viewParent.headerText"
                            android:textColor="@color/violet"
                            android:textSize="27sp"
                            android:layout_marginLeft="30dp"
                            />
                        <TextView
                            android:id="@+id/calorieV"
                            style="@style/viewParent.headerText"
                            android:layout_marginLeft="27dp"
                            android:textSize="16sp"
                            />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>
            </LinearLayout>




        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/activity_chip_bar"


        />


</androidx.constraintlayout.widget.ConstraintLayout>
