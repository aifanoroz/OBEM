<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".SettingActivity"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
 >

    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/obem_header_bk"
        android:paddingLeft="20dp"
        android:paddingTop="40dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp"
        android:layout_marginBottom="630dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="600dp"
        android:orientation="vertical"
        android:padding="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">


        <TextView
            style="@style/viewParent.headerText"
            android:text="Settings"
            android:textColor="@color/whiteTextColor"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profilepicture"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_marginTop="50dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/ic_edit_profile"
                app:civ_border_color="@color/violet"
                app:civ_border_width="2dp" />

            <TextView
                android:id="@+id/username"
                style="@style/viewParent.headerText"
                android:layout_marginTop="50dp"
                android:layout_toRightOf="@id/profilepicture"
                android:textColor="@color/black"
                android:textSize="18sp" />

            <TextView
                style="@style/viewParent.headerText"
                android:layout_below="@id/username"
                android:layout_toRightOf="@id/profilepicture"
                android:text="Edit personal details"
                android:textColor="#5D5C5C"
                android:textSize="16sp" />

            <ImageView
                style="@style/viewParent"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/h" />

        </RelativeLayout>


        <TextView
            style="@style/viewParent.headerText.settingsMiniTitle"
            android:text="Profile"
            android:layout_marginTop="50dp"/>

        <TextView
            android:id="@+id/wu"
            style="@style/viewParent.headerText.settingsTextIcon"
            android:drawableLeft="@drawable/ic_edit_profile"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:text="Weekly Update " />

        <TextView
            android:id="@+id/cpass"
            style="@style/viewParent.headerText.settingsTextIcon"
            android:layout_marginTop="30dp"
            android:drawableLeft="@drawable/ic_edit_password"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:text="Change Password" />

        <TextView
            style="@style/viewParent.headerText.settingsMiniTitle"
            android:layout_marginTop="50dp"
            android:text="Regional" />


        <TextView
            android:id="@+id/logout"
            style="@style/viewParent.headerText.settingsTextIcon"
            android:drawableLeft="@drawable/ic_logout"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:text="Logout" />


    </LinearLayout>


    <RelativeLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/obem_header_bk"
        android:paddingLeft="20dp"
        android:paddingTop="40dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
        app:layout_constraintVertical_bias="1.0" />


</androidx.constraintlayout.widget.ConstraintLayout>