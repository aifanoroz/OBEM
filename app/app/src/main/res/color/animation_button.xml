<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item  android:state_activated="true" android:color="@color/violet"/>
    <item   android:color="@color/lavender">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/lavender"
                android:endColor="@color/violet"
                android:angle="270">
            </gradient>
            <stroke
                android:width="1dp"
                android:color="#FFF" />
            <corners
                android:radius="10dp"/>
        </shape>
    </item>
    <item android:state_activated="true" android:color="@color/violet"/>
    <item   android:color="@color/lavender">
        <shape android:shape="rectangle">
            <solid
                android:color="@color/lavender" />
            <stroke
                android:width="2dp"
                android:color="#222222" />
        </shape>
    </item>




</selector>